<odoo>
    <!-- LANGKAH 1: Paksa noupdate menjadi False (0) agar record bisa diedit kembali -->
    <function model="ir.model.data" name="write">
        <function model="ir.model.data" name="search">
            <value eval="[('module', '=', 'base'), ('name', '=', 'main_company')]"/>
        </function>
        <value eval="{'noupdate': False}"/>
    </function>

    <!-- LANGKAH 2: Update datanya -->
    <record id="base.main_company" model="res.company">
        <field name="logo" type="base64" file="general/static/src/img/logo.png"/>
        <field name="name">PT KSI Solusi</field>
        <field name="street">Medang Lestari</field>
        <field name="street2">Kec. Pagedangan</field>
        <field name="city">Kab. Tangerang</field>
        <field name="zip">15334</field>
        <field name="phone">+62 812 3456 7890</field>
    </record>

    <!-- LANGKAH 3: Kembalikan noupdate menjadi True (Opsional) -->
    <function model="ir.model.data" name="write">
        <function model="ir.model.data" name="search">
            <value eval="[('module', '=', 'base'), ('name', '=', 'main_company')]"/>
        </function>
        <value eval="{'noupdate': True}"/>
    </function>
</odoo>
