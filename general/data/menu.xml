<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="country_menu" model="general.menu">
        <field name="menu_id">country</field>
        <field name="menu_name">Countries</field>
        <field name="parent_menu">others</field>
    </record>
    <record id="state_menu" model="general.menu">
        <field name="menu_id">state</field>
        <field name="menu_name">State</field>
        <field name="parent_menu">others</field>
    </record>
    <record id="city_menu" model="general.menu">
        <field name="menu_id">city</field>
        <field name="menu_name">Cities</field>
        <field name="parent_menu">others</field>
    </record>
    <record id="district_menu" model="general.menu">
        <field name="menu_id">district</field>
        <field name="menu_name">Districts</field>
        <field name="parent_menu">others</field>
    </record>
    <record id="position_menu" model="general.menu">
        <field name="menu_id">position</field>
        <field name="menu_name">Positions</field>
        <field name="parent_menu">others</field>
    </record>
    <record id="department_menu" model="general.menu">
        <field name="menu_id">department</field>
        <field name="menu_name">Departments</field>
        <field name="parent_menu">others</field>
    </record>
    <record id="users_menu" model="general.menu">
        <field name="menu_id">custom_users</field>
        <field name="menu_name">Users</field>
        <field name="parent_menu">master_data</field>
    </record>
    <record id="others_menu" model="general.menu">
        <field name="menu_id">others</field>
        <field name="menu_name">Others</field>
        <field name="parent_menu">master_data</field>
        <field name="is_parent">True</field>
    </record>
    <record id="master_data_menu" model="general.menu">
        <field name="menu_id">master_data</field>
        <field name="menu_name">Configuration</field>
        <field name="is_parent">True</field>
    </record>
    <record id="approvals_menu_root" model="general.menu">
        <field name="menu_id">approvals</field>
        <field name="menu_name">Approvals</field>
        <field name="is_parent">True</field>
    </record>
    <record id="approvals_config_menu" model="general.menu">
        <field name="menu_id">approvals_config</field>
        <field name="menu_name">Approval</field>
        <field name="parent_menu">master_data</field>
        <field name="is_parent">True</field>
    </record>
</odoo>
