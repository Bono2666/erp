<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">    
        <record id="email_template_sales_approval_request" model="mail.template">
            <field name="name">Sales Order: Approval Request</field>
            <field name="model_id" ref="sales.model_sales_sales_order"/>
            <field name="subject">Persetujuan Diperlukan: ${object.sales_code} - ${object.customer_id.customer_name}</field>
            <field name="email_from">${(object.sales_name.user_id.login) | safe}</field>
            <field name="email_to">${ctx.get('email_to') | safe}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px; font-family: 'Arial', sans-serif;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Halo <strong>${ctx.get('approver_name')}</strong>,<br/><br/>
                        Mohon tinjau permintaan persetujuan untuk pesanan penjualan berikut:
                        <br/><br/>
                        <strong>Nomor Order:</strong> ${object.sales_code}<br/>
                        <strong>Pelanggan:</strong> ${object.customer_id.customer_name}<br/>
                        <strong>Total Nilai:</strong> ${format_amount(object.total_amount, 'Rp')}<br/>
                        <strong>Salesman:</strong> ${object.sales_name.name}<br/>
                        <br/>
                        Sistem mendeteksi adanya <strong>Diskon Khusus</strong> yang memerlukan otorisasi dari posisi Anda sebagai <em>${ctx.get('position')}</em>.
                        <br/><br/>
                        Silakan klik tombol di bawah ini untuk melihat detail dan memberikan keputusan:
                        <br/><br/>
                        <center>
                            <a href="/web#id=${object.id}&amp;model=sales.sales_order&amp;view_type=form" 
                            style="background-color: #875A7B; padding: 10px 20px; text-decoration: none; color: #fff; border-radius: 5px; font-size: 14px;">
                            Lihat Pesanan Penjualan
                            </a>
                        </center>
                        <br/><br/>
                        Terima kasih.
                    </p>
                </div>
            </field>
        </record>
    </data>
</odoo>
