<odoo>
    <data noupdate="0">
        <record id="action_report_sales_order" model="ir.actions.report">
            <field name="name">Quotation / Sales Order</field>
            <field name="model">sales.sales_order</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">sales.report_sales_order_template</field>
            <field name="report_file">sales.report_sales_order_template</field>
            <field name="print_report_name">'Quotation - %s' % (object.sales_code)</field>
            <field name="binding_model_id" ref="model_sales_sales_order"/>
            <field name="binding_type">report</field>
        </record>
        <record id="action_report_sales_invoice" model="ir.actions.report">
            <field name="name">Sales Invoice</field>
            <field name="model">sales.invoice</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">sales.report_sales_invoice_template</field>
            <field name="report_file">sales.report_sales_invoice_template</field>
            <field name="print_report_name">'Invoice - %s' % (object.invoice_number)</field>
            <field name="binding_model_id" ref="model_sales_invoice"/>
            <field name="binding_type">report</field>
        </record>
        <record id="email_template_compressor_quotation" model="mail.template">
            <field name="name">Sales: Compressor Quotation</field>
            <field name="model_id" ref="sales.model_sales_sales_order"/>
            <field name="subject">Quotation {{ object.sales_code }} - {{ object.customer_id.customer_name }}</field>
            <field name="email_from">{{ object.sales_name.login }}</field>
            <field name="partner_to">{{ object.customer_id.partner_id.id }}</field>
            <field name="description">Sent to customers when a quotation is ready</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Yth. <strong><t t-out="object.customer_id.customer_name"/></strong>,<br/><br/>
                        Terima kasih atas ketertarikan Anda terhadap produk kompresor kami.
                        Kami dengan senang hati mengirimkan penawaran harga <strong><t t-out="object.sales_code"/></strong> 
                        dengan total nilai sebesar <strong><t t-out="object.env['res.lang']._lang_get('en_US').format('%d', object.total_amount, grouping=True)"/></strong>.
                        <br/><br/>
                        Detail spesifikasi teknis telah kami lampirkan dalam format PDF pada email ini.
                        <br/><br/>
                        Jika Anda memiliki pertanyaan lebih lanjut, jangan ragu untuk menghubungi kami.
                        <br/><br/>
                        Hormat kami,<br/>
                        <strong><t t-out="object.sales_name.name"/></strong>
                    </p>
                </div>
            </field>
            <field name="report_template_ids" eval="[(6, 0, [ref('sales.action_report_sales_order')])]"/>
        </record>
        <record id="email_template_sales_invoice" model="mail.template">
            <field name="name">Sales: Invoice</field>
            <field name="model_id" ref="sales.model_sales_invoice"/>
            <field name="subject">Invoice {{ object.invoice_number }} - {{ object.customer_id.customer_name }}</field>
            <field name="email_from">{{ object.sales_name.user_id.email or object.sales_name.user_id.login or user.email or (object.env.company.email or '') }}</field>
            <field name="partner_to">{{ object.customer_id.partner_id.id }}</field>
            <field name="description">Sent to customers when an invoice is posted</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Yth. <strong><t t-out="object.customer_id.customer_name"/></strong>,<br/><br/>
                        Bersama email ini kami sampaikan invoice
                        <strong><t t-out="object.invoice_number"/></strong>
                        dengan total tagihan sebesar
                        <strong>Rp <t t-out="'{:,.0f}'.format(object.amount_total)"/></strong>.
                        <br/><br/>
                        Mohon segera melakukan pembayaran sesuai dengan termin yang telah disepakati.
                        <br/><br/>
                        Jika Anda memiliki pertanyaan, jangan ragu untuk menghubungi kami.
                        <br/><br/>
                        Hormat kami,<br/>
                        <strong><t t-out="object.sales_name.name or ''"/></strong>
                    </p>
                </div>
            </field>
            <!-- Auto-attach Invoice PDF -->
            <field name="report_template_ids" eval="[(6, 0, [ref('sales.action_report_sales_invoice')])]"/>
        </record>
    </data>
</odoo>
