<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- HCM Custom Menu Records for Authorization System -->
    <record id="hcm_employee_menu" model="general.menu">
        <field name="menu_id">hcm_employee</field>
        <field name="menu_name">Employees</field>
        <field name="parent_menu">hcm</field>
    </record>
    <record id="hcm_position_menu" model="general.menu">
        <field name="menu_id">hcm_position</field>
        <field name="menu_name">Positions</field>
        <field name="parent_menu">hcm</field>
    </record>
    <record id="hcm_org_structure_menu" model="general.menu">
        <field name="menu_id">hcm_org_structure</field>
        <field name="menu_name">Organization Structure</field>
        <field name="parent_menu">hcm</field>
    </record>
    <record id="hcm_parent_menu" model="general.menu">
        <field name="menu_id">hcm</field>
        <field name="menu_name">HCM</field>
        <field name="is_parent">True</field>
    </record>

</odoo>
