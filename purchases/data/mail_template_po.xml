<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="email_template_purchase_order" model="mail.template">
            <field name="name">Purchase Order: Send to Vendor</field>
            <field name="model_id" ref="purchases.model_purchases_purchase_order"/>
            <field name="subject">Purchase Order {{ object.po_code }} - {{ object.env.company.name }}</field>
            <field name="email_from">{{ object.buyer_id.user_id.email or object.buyer_id.user_id.login or user.email or (object.env.company.email or '') }}</field>
            <field name="email_to">{{ object.vendor_id.email or '' }}</field>
            <field name="description">Sent to vendor when a purchase order is confirmed</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Yth. <strong><t t-out="object.vendor_id.vendor_name"/></strong>,<br/><br/>
                        Bersama email ini kami sampaikan Purchase Order
                        <strong><t t-out="object.po_code"/></strong>
                        dengan total nilai sebesar
                        <strong>Rp <t t-out="'{:,.0f}'.format(object.total_amount)"/></strong>.
                        <br/><br/>
                        Detail Purchase Order terlampir dalam format PDF.
                        <br/><br/>
                        Mohon konfirmasi penerimaan Purchase Order ini.
                        <br/><br/>
                        Hormat kami,<br/>
                        <strong><t t-out="object.buyer_id.name or ''"/></strong><br/>
                        <t t-out="object.env.company.name or ''"/>
                    </p>
                </div>
            </field>
            <field name="report_template_ids" eval="[(6, 0, [ref('purchases.action_report_purchase_order')])]"/>
        </record>
    </data>
</odoo>
