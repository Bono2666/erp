<odoo>
    <data>

        <!-- Purchase Order PDF Report Template -->
        <template id="report_purchase_order_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <div class="oe_structure"/>
                            <h2 class="mt-4">
                                <span>Purchase Order # </span>
                                <span t-field="doc.po_code"/>
                            </h2>

                            <div class="row mt-4 mb-4">
                                <div class="col-6">
                                    <strong><span t-field="doc.vendor_id.vendor_name"/></strong><br/>
                                    <span t-field="doc.vendor_id.address"/><br/>
                                    <t t-if="doc.vendor_id.city">
                                        <span t-field="doc.vendor_id.city.city_name"/><span>, </span>
                                    </t>
                                    <t t-if="doc.vendor_id.state">
                                        <span t-field="doc.vendor_id.state.state_name"/>
                                    </t>
                                    <br/>
                                    <span t-field="doc.vendor_id.country.country_name"/>
                                </div>
                                <div class="col-6 text-end">
                                    <table class="table table-sm table-borderless">
                                        <tr>
                                            <td class="text-end"><strong>Order Date</strong></td>
                                            <td class="text-end"><span t-field="doc.po_date"/></td>
                                        </tr>
                                        <t t-if="doc.delivery_date">
                                            <tr>
                                                <td class="text-end"><strong>Delivery Date</strong></td>
                                                <td class="text-end"><span t-field="doc.delivery_date"/></td>
                                            </tr>
                                        </t>
                                        <t t-if="doc.payment_terms">
                                            <tr>
                                                <td class="text-end"><strong>Payment Terms</strong></td>
                                                <td class="text-end"><span t-field="doc.payment_terms.sales_text"/></td>
                                            </tr>
                                        </t>
                                        <t t-if="doc.buyer_id">
                                            <tr>
                                                <td class="text-end"><strong>Buyer</strong></td>
                                                <td class="text-end"><span t-field="doc.buyer_id.name"/></td>
                                            </tr>
                                        </t>
                                    </table>
                                </div>
                            </div>

                            <table class="table table-sm o_main_table mt-4">
                                <thead>
                                    <tr>
                                        <th class="text-start">#</th>
                                        <th class="text-start">Description</th>
                                        <th class="text-end">Qty</th>
                                        <th class="text-end">Unit Price</th>
                                        <th class="text-end">Tax</th>
                                        <th class="text-end">Sub Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.order_line_ids" t-as="line">
                                        <tr>
                                            <td><span t-esc="line_index + 1"/></td>
                                            <td>
                                                <span t-field="line.product_id.product_name"/>
                                                <t t-if="line.description and line.description != line.product_id.product_name">
                                                    <br/><small class="text-muted"><span t-field="line.description"/></small>
                                                </t>
                                            </td>
                                            <td class="text-end">
                                                <span t-field="line.quantity"/>
                                                <t t-if="line.product_unit"> <span t-field="line.product_unit.uom"/></t>
                                            </td>
                                            <td class="text-end"><span t-field="line.unit_price"/></td>
                                            <td class="text-end">
                                                <t t-if="line.taxes"><span t-field="line.taxes.name"/></t>
                                                <t t-else="">-</t>
                                            </td>
                                            <td class="text-end"><span t-field="line.sub_total"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>

                            <div class="row justify-content-end">
                                <div class="col-4">
                                    <table class="table table-sm">
                                        <tr>
                                            <td><strong>Untaxed Amount</strong></td>
                                            <td class="text-end"><span t-field="doc.total_amount_untaxed"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Tax</strong></td>
                                            <td class="text-end"><span t-field="doc.total_tax"/></td>
                                        </tr>
                                        <tr class="border-black o_total">
                                            <td><strong>Total</strong></td>
                                            <td class="text-end"><span t-field="doc.total_amount"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            <t t-if="doc.note">
                                <div class="row mt-4">
                                    <div class="col-12">
                                        <p t-field="doc.note"/>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>
